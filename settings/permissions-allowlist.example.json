{
  "_comment": "Common read-only commands worth pre-allowing to cut down on permission prompts. Review before merging into a real settings.json.",
  "allow": [
    "Bash(git status)",
    "Bash(git diff*)",
    "Bash(git log*)",
    "Bash(git branch*)",
    "Bash(git show*)",
    "Bash(git remote -v)",
    "Bash(ls*)",
    "Bash(cat package.json)",
    "Bash(cat tsconfig.json)",
    "Bash(npm test*)",
    "Bash(npm run build*)",
    "Bash(npm run lint*)",
    "Bash(npm run typecheck*)",
    "Bash(npx tsc --noEmit)",
    "Bash(pytest*)",
    "Bash(ruff check*)",
    "Bash(python -m pytest*)",
    "Bash(cargo test*)",
    "Bash(cargo check*)",
    "Bash(cargo clippy*)",
    "Bash(go test*)",
    "Bash(go vet*)"
  ]
}
